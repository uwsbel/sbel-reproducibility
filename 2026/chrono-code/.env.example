# ========================================
# Default LLM Provider
# ========================================
# One of: anthropic, openai, ngc, huggingface, ollama, minimax, deepseek, google
DEFAULT_LLM_PROVIDER=openai

# ========================================
# Provider Credentials (fill in the ones you use)
# ========================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
NGC_API_KEY=
HUGGINGFACE_API_TOKEN=

# ========================================
# Default Models per Provider
# ========================================
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4.1
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_API_BASE=https://api.minimaxi.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_BASE=https://api.deepseek.com
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ========================================
# Per-Agent Overrides
# Agents: 1=Planning, 2=CodeGen, 3=Review (VLM), 4=Execution
# Each agent can use a different provider/model; leave unset to use defaults.
# ========================================

# Agent 1: Planning
AGENT1_LLM_PROVIDER=openai
AGENT1_MODEL=gpt-5
AGENT1_TEMPERATURE=1.0
AGENT1_MAX_TOKENS=16384

# Agent 2: Code Generation
AGENT2_LLM_PROVIDER=minimax
AGENT2_MODEL=minimax-m2.7-highspeed
AGENT2_TEMPERATURE=0.3

# Agent 3: Visual Review (VLM)
AGENT3_LLM_PROVIDER=google
AGENT3_MODEL=gemini-2.5-pro
AGENT3_TEMPERATURE=0.3
AGENT3_MAX_TOKENS=4096

# Agent 4: Execution
AGENT4_LLM_PROVIDER=openai
AGENT4_MODEL=gpt-4.1
AGENT4_TEMPERATURE=0.3

